{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build active dir",
      "type": "shell",
      "command": "gcc",
      "args": [
        "${fileDirname}\\*.c",
        "-g",
        "-o",
        "${fileDirname}\\${fileBasenameNoExtension}.exe"
      ],
      "options": { "cwd": "${fileDirname}" },
      "problemMatcher": ["$gcc"],
      "group": { "kind": "build", "isDefault": true }
    }
  ]
}